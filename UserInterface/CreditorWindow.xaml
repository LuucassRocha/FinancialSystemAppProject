<Window x:Class="UserInterface.CreditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UserInterface"
        mc:Ignorable="d"
        Title="Creditor Registration" Height="650" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Creditor Registration"
           FontSize="20" FontWeight="Bold"
           HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Label Content="Name:"/>
            <TextBox x:Name="txtCredName" Margin="0,0,0,10"/>

            <Label Content="Document:"/>
            <TextBox x:Name="txtCredDocument" Margin="0,0,0,10"/>

            <Label Content="Email:"/>
            <TextBox x:Name="txtCredEmail" Margin="0,0,0,10"/>

            <Label Content="Phone:"/>
            <TextBox x:Name="txtCredPhone" Margin="0,0,0,10"/>

            <Label Content="Address:"/>
            <TextBox x:Name="txtCredAddress" Margin="0,0,0,10"/>

            <Button x:Name="btnAddPerson"
            Content="Add Creditor"
            Click="BtnAddCred_Click"
            Background="LightGray" Padding="10" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Registered Creditors:" FontWeight="Bold"/>
            <ListBox x:Name="lstCreditors" Height="150"/>
            <TextBlock x:Name="txtCounter" Margin="0,5,0,0" FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</Window>
